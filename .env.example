# whisk — environment configuration
#
# The OpenAI layer is OPTIONAL. Leave these blank and whisk runs fully on
# deterministic Wikipedia-only signals (search, clustering, rabbit-hole
# narration all still work). Add a key to enable AI query expansion, smarter
# cluster labels, "why this matched" explanations, and richer path narration.
#
# The key is used ONLY by the server-side proxy at /api/ai — it is NOT prefixed
# with VITE_, so it is never bundled into the client and never reaches the
# browser. Set the same values in your Vercel project's Environment Variables.

# --- Server-side only (never sent to the browser) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini            # optional, defaults to gpt-4o-mini

# --- Client flag (safe, non-secret) ---
# Set to "true" wherever OPENAI_API_KEY is configured so the UI reflects AI and
# the app makes calls. Leave blank/false to force Wikipedia-only mode.
VITE_AI_ENABLED=true

# --- Trending rabbit holes (optional, server-side) ---
# Google Trends region for the Home page "Trending rabbit holes". No key is
# required — the feed is public and proxied through /api/trends. Defaults to US.
# TRENDS_GEO=US
#
# Trends caching (client localStorage + server in-memory memo) is PROD-ONLY by
# default, so local dev always fetches fresh. Override the defaults:
#   VITE_TRENDS_CACHE=true|false   (client cache; defaults to import.meta.env.PROD)
#   TRENDS_CACHE=true|false        (server memo; defaults to NODE_ENV==='production')
# VITE_TRENDS_CACHE=false
# TRENDS_CACHE=false

# --- Sitemap origin (optional, build-time) ---
# Absolute origin used for sitemap.xml / robots.txt URLs. On Vercel this is
# auto-detected from VERCEL_PROJECT_PRODUCTION_URL, so only set this if you use
# a custom production domain (e.g. https://whisk.app).
# SITE_URL=https://whisk.app
